{
	"name": "sokos-up-spk-mottak",
	"version": "1.0.0",
	"description": "Mikrofrontend for Utbetalingsportalen",
	"type": "module",
	"scripts": {
		"dev": "vite --mode mock",
		"dev:backend": "vite --mode backend",
		"dev:backend-q1": "vite --mode backend-q1",
		"build": "tsc && vite build",
		"biome:check": "biome check --files-ignore-unknown=true",
		"biome:fix": "biome check --write --no-errors-on-unmatched",
		"stylelint:check": "stylelint '**/*.css'",
		"stylelint:fix": "stylelint '**/*.css' --fix",
		"prepare": "husky",
		"pnpm:resolve": "node scripts/resolve-pnpm-version.mjs"
	},
	"dependencies": {
		"@grafana/faro-web-sdk": "2.5.0",
		"@navikt/aksel-icons": "7.40.0",
		"@navikt/ds-css": "7.40.0",
		"@navikt/ds-react": "7.40.0",
		"axios": "1.16.0",
		"dayjs": "1.11.20",
		"react": "19.2.5",
		"react-dom": "19.2.5",
		"swr": "2.4.1",
		"zod": "4.4.3",
		"zustand": "5.0.13"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.14",
		"@navikt/aksel-stylelint": "7.40.0",
		"@types/node": "25.6.0",
		"@types/react": "19.2.14",
		"@types/react-dom": "19.2.3",
		"@vitejs/plugin-react": "6.0.1",
		"husky": "9.1.7",
		"lint-staged": "16.4.0",
		"msw": "2.14.3",
		"stylelint": "17.11.0",
		"stylelint-config-standard": "40.0.0",
		"typescript": "6.0.3",
		"vite": "8.0.10",
		"vite-plugin-css-injected-by-js": "5.0.1"
	},
	"msw": {
		"workerDirectory": [
			"public"
		]
	},
	"stylelint": {
		"extends": [
			"stylelint-config-standard",
			"@navikt/aksel-stylelint/recommended"
		],
		"rules": {
			"selector-class-pattern": null
		}
	},
	"lint-staged": {
		"*.{js,ts,cjs,mjs,d.cts,d.mts,jsx,tsx,json,jsonc}": "biome check --write --no-errors-on-unmatched",
		"*.css": "stylelint --fix"
	},
	"engines": {
		"pnpm": ">=11.0.8",
		"node": ">=24.14.1"
	},
	"packageManager": "pnpm@11.0.8+sha512.4c4097e1dd2d42372c4e7fa5a791ff28fc75a484c7ac192e64b1df0fdef17594ba982f9b4fed9adfb3c757846f565b799b2763fb3733d1de1bcb82cf46684912"
}
