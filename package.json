{
	"name": "sokos-up-spk-mottak",
	"version": "1.0.0",
	"description": "Mikrofrontend for Utbetalingsportalen",
	"type": "module",
	"scripts": {
		"dev": "vite --mode mock",
		"dev:backend": "vite --mode backend",
		"dev:backend-q1": "vite --mode backend-q1",
		"build": "tsc && vite build",
		"biome:check": "biome check --files-ignore-unknown=true",
		"biome:fix": "biome check --write --no-errors-on-unmatched",
		"stylelint:check": "stylelint '**/*.css'",
		"stylelint:fix": "stylelint '**/*.css' --fix",
		"prepare": "husky"
	},
	"dependencies": {
		"@grafana/faro-web-sdk": "2.3.1",
		"@navikt/aksel-icons": "7.40.0",
		"@navikt/ds-css": "7.40.0",
		"@navikt/ds-react": "7.40.0",
		"axios": "1.15.2",
		"dayjs": "1.11.20",
		"react": "19.2.5",
		"react-dom": "19.2.5",
		"swr": "2.4.1",
		"zod": "4.3.6",
		"zustand": "5.0.12"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.12",
		"@navikt/aksel-stylelint": "7.40.0",
		"@types/node": "25.6.0",
		"@types/react": "19.2.14",
		"@types/react-dom": "19.2.3",
		"@vitejs/plugin-react": "6.0.1",
		"autoprefixer": "10.5.0",
		"husky": "9.1.7",
		"lint-staged": "16.4.0",
		"msw": "2.13.4",
		"postcss": "8.5.10",
		"stylelint": "17.8.0",
		"stylelint-config-standard": "40.0.0",
		"typescript": "6.0.3",
		"vite": "8.0.9",
		"vite-plugin-css-injected-by-js": "5.0.1"
	},
	"msw": {
		"workerDirectory": [
			"public"
		]
	},
	"browserslist": {
		"production": [
			">0.2%",
			"not dead",
			"not op_mini all"
		],
		"development": [
			"last 1 chrome version",
			"last 1 firefox version"
		]
	},
	"stylelint": {
		"extends": [
			"stylelint-config-standard",
			"@navikt/aksel-stylelint/recommended"
		],
		"rules": {
			"selector-class-pattern": null
		}
	},
	"lint-staged": {
		"*.{js,ts,cjs,mjs,d.cts,d.mts,jsx,tsx,json,jsonc}": "biome check --write --no-errors-on-unmatched",
		"*.css": "stylelint --fix"
	},
	"engines": {
		"pnpm": ">=10.16.0",
		"node": ">=24.13.0"
	},
	"pnpm": {
		"overrides": {
            "fast-uri": "3.1.2"
        }
	}
}
